---
import AscentMark from './AscentMark.astro';
import { COPY, oppositeLang, type Lang } from '../data/content.ts';

interface Props {
  lang: Lang;
  current: 'home' | 'courses' | 'register' | 'about' | 'course';
}
const { lang, current } = Astro.props;
const t = COPY[lang];
const other = oppositeLang(lang);

const links = [
  { key: 'courses',  label: t.nav.courses,  href: `/${lang}/courses` },
  { key: 'register', label: t.nav.register, href: `/${lang}/register` },
  { key: 'about',    label: t.nav.about,    href: `/${lang}/about` },
] as const;

// Preserve page when switching language
const path = Astro.url.pathname.replace(/^\/(en|ar)/, '') || '';
const toggleHref = `/${other}${path}`;

const toggleShort = lang === 'en' ? 'AR' : 'EN';
---

<nav class="sticky top-0 z-20 bg-cream border-b border-black/8 px-4 md:px-12 py-4 md:py-5 flex items-center justify-between gap-3 md:gap-0">
  <a href={`/${lang}`} class="flex items-center gap-2 md:gap-3 no-underline shrink-0">
    <AscentMark size={28} fgClass="fill-ink" notchClass="fill-cream" />
    {lang === 'en' ? (
      <>
        <span class="font-serif text-[20px] md:text-[22px] font-medium tracking-[-0.02em] text-ink">hema</span>
        <span class="hidden md:inline font-arabic text-[20px] text-ink ms-1">همّة</span>
      </>
    ) : (
      <>
        <span class="font-arabic text-[20px] md:text-[22px] text-ink">همّة</span>
        <span class="hidden md:inline font-serif text-[22px] font-medium tracking-[-0.02em] text-ink ms-1">hema</span>
      </>
    )}
  </a>

  <div class="flex gap-2.5 md:gap-7 items-center">
    {links.map((l) => (
      <a
        href={l.href}
        class:list={[
          'text-[12px] md:text-[13px] no-underline pb-[3px] border-b-[1.5px] transition-colors whitespace-nowrap',
          current === l.key
            ? 'text-ink font-semibold border-clay'
            : 'text-black/65 font-medium border-transparent hover:text-ink',
        ]}
      >
        {l.label}
      </a>
    ))}
    <a
      href={toggleHref}
      class="bg-transparent border border-ink text-ink px-2 md:px-3 py-1 md:py-1.5 text-[10px] md:text-[11px] tracking-[1.5px] md:tracking-[2px] font-semibold no-underline hover:bg-ink hover:text-cream transition-colors shrink-0"
    >
      <span class="md:hidden">{toggleShort}</span>
      <span class="hidden md:inline">{t.langToggle}</span>
    </a>
  </div>
</nav>
