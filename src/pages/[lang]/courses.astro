---
import Base from '../../layouts/Base.astro';
import { COPY, COURSES, LOCALES, type Lang } from '../../data/content.ts';

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = COPY[lang];
---

<Base lang={lang} current="courses" title={`${t.nav.courses} — Hema Academy`}>
  <section class="px-6 md:px-12 pt-20 pb-10">
    <div class="eyebrow mb-4">{t.nav.courses}</div>
    <h1 class="h-serif text-[44px] md:text-[64px] mb-4">{t.coursesPage.title}</h1>
    <p class="text-[15px] text-black/60 max-w-[620px] leading-relaxed">{t.coursesPage.sub}</p>
  </section>

  <section class="px-6 md:px-12 pb-20 grid grid-cols-1 gap-6">
    {COURSES.map((c) => (
      <a
        href={`/${lang}/courses/${c.id}`}
        class="p-10 md:p-14 no-underline flex flex-col min-h-[320px] cursor-pointer transition-transform hover:-translate-y-0.5 bg-ink text-cream"
      >
        <div class="text-[10px] tracking-[3px] font-semibold opacity-70 mb-4">{c.duration[lang].toUpperCase()}</div>
        <div class="font-serif text-[32px] md:text-[44px] tracking-[-0.025em] leading-tight mb-4 flex-1 max-w-[760px]">{c.title[lang]}</div>
        <div class="text-[14px] leading-relaxed opacity-80 mb-6 max-w-[640px]">{c.tagline[lang]}</div>
        <div class="text-[11px] tracking-[2px] font-semibold pt-4 flex justify-between border-t border-white/20">
          <span>{c.next[lang]}</span><span>{t.cta.syllabus} →</span>
        </div>
      </a>
    ))}
  </section>
</Base>
