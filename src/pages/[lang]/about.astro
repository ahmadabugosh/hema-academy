---
import Base from '../../layouts/Base.astro';
import AscentMark from '../../components/AscentMark.astro';
import { COPY, TEAM, LOCALES, type Lang } from '../../data/content.ts';

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = COPY[lang];
const a = t.about;
---

<Base lang={lang} current="about" title={`${t.nav.about} — Hema Academy`}>
  <section class="px-6 md:px-12 pt-20 pb-14">
    <div class="eyebrow mb-4">{a.eyebrow}</div>
    <h1 class="font-serif text-[44px] md:text-[68px] font-normal tracking-[-0.03em] leading-none mb-5 max-w-[900px]">{a.title}</h1>
    <p class="text-[15px] md:text-[17px] text-black/65 leading-relaxed max-w-[720px]">{a.sub}</p>
  </section>

  <section class="px-6 md:px-12 py-14 bg-sand grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14">
    <div>
      <div class="eyebrow mb-3.5">01</div>
      <h2 class="font-serif text-[28px] md:text-[36px] font-normal tracking-[-0.025em] leading-tight mb-4">{a.nameTitle}</h2>
      <p class="text-[15px] text-black/70 leading-relaxed">{a.nameBody}</p>
      <div class="font-arabic text-[96px] text-clay leading-none mt-8">همّة</div>
    </div>
    <div>
      <div class="eyebrow mb-3.5">02</div>
      <h2 class="font-serif text-[28px] md:text-[36px] font-normal tracking-[-0.025em] leading-tight mb-4">{a.markTitle}</h2>
      <p class="text-[15px] text-black/70 leading-relaxed">{a.markBody}</p>
      <div class="mt-8">
        <AscentMark size={160} fgClass="fill-ink" notchClass="fill-sand" />
      </div>
    </div>
  </section>

  <section class="px-6 md:px-12 py-20">
    <div class="eyebrow mb-3">03</div>
    <h2 class="font-serif text-[34px] md:text-[44px] font-normal tracking-[-0.03em] leading-[1.05] mb-2.5">{a.teamTitle}</h2>
    <p class="text-[15px] text-black/60 max-w-[580px] mb-10">{a.teamSub}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {TEAM.map((p) => (
        <div class="grid grid-cols-[120px_1fr] md:grid-cols-[140px_1fr] gap-5 md:gap-6 p-6 border border-black/8 bg-cream">
          {p.photo ? (
            <img
              src={p.photo}
              alt={p.name[lang]}
              class="w-[120px] h-[120px] md:w-[140px] md:h-[140px] object-cover"
            />
          ) : (
            <div class:list={['w-[120px] h-[120px] md:w-[140px] md:h-[140px] flex items-center justify-center font-serif text-[40px] md:text-[48px] tracking-[-0.02em] font-normal', p.colorClass, p.textClass]}>
              {p.initials}
            </div>
          )}
          <div>
            <div class="font-serif text-[22px] tracking-[-0.02em] mb-0.5">{p.name[lang]}</div>
            <div class="text-[11px] tracking-[2px] text-clay font-semibold mb-3 uppercase">{p.role[lang]}</div>
            {p.bio && (
              <p class="text-[13px] text-black/70 leading-relaxed m-0 mb-3.5">{p.bio[lang]}</p>
            )}
            {p.linkedin && (
              <div class="flex flex-wrap gap-2.5">
                <a
                  href={p.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[10px] tracking-[1.5px] font-semibold px-2.5 py-1 border border-black/20 text-black/70 uppercase no-underline hover:bg-ink hover:text-cream hover:border-ink transition-colors"
                >
                  LinkedIn →
                </a>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
